@page "/manual"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject BogDb.Samples.MonsterManual.Blazor.Services.MonsterGraphService Svc

<PageTitle>Monster Browser · BogDb</PageTitle>

<div class="page-header">
    <h1 class="page-title">📙 Monster Manual</h1>
    <p class="page-subtitle">Filter the bestiary by attribute ranges, then use the arrows to browse matching entries one at a time.</p>
</div>

<div style="display:flex;gap:32px;align-items:flex-start">

    <!-- Left: filter + cypher panel -->
    <div style="width:300px;flex-shrink:0;">
        <div class="card" style="padding:20px 18px;">
            <div class="card-title" style="font-size:15px;margin-bottom:16px;">Physical Attributes</div>

            <div class="range-slider">
                <div class="range-label"><span>STR (@_minStr)</span><span>(@_maxStr)</span></div>
                <div class="range-row">
                    <input type="range" min="0" max="30" @bind="_minStr" @bind:event="oninput" />
                    <input type="range" min="0" max="30" @bind="_maxStr" @bind:event="oninput" />
                </div>
            </div>

            <div class="range-slider" style="margin-top:16px">
                <div class="range-label"><span>DEX (@_minDex)</span><span>(@_maxDex)</span></div>
                <div class="range-row">
                    <input type="range" min="0" max="30" @bind="_minDex" @bind:event="oninput" />
                    <input type="range" min="0" max="30" @bind="_maxDex" @bind:event="oninput" />
                </div>
            </div>

            <div class="range-slider" style="margin-top:16px">
                <div class="range-label"><span>CON (@_minCon)</span><span>(@_maxCon)</span></div>
                <div class="range-row">
                    <input type="range" min="0" max="30" @bind="_minCon" @bind:event="oninput" />
                    <input type="range" min="0" max="30" @bind="_maxCon" @bind:event="oninput" />
                </div>
            </div>

            <button class="btn btn-primary" style="width:100%;margin-top:20px;padding:12px" @onclick="Search">
                🔍 Filter Bestiary
            </button>
        </div>

        @if (_lastQuery != null)
        {
            <div class="card" style="padding:16px;">
                <div class="card-title" style="font-size:13px;margin-bottom:8px">Executed Cypher</div>
                <div class="cyber-code" style="font-size:10px;padding:10px">@_lastQuery</div>
            </div>
        }
    </div>

    <!-- Right: single card cursor viewer -->
    <div style="flex:1;min-width:0">
        @if (_error != null)
        {
            <div class="card" style="text-align:center;padding:48px 32px;">
                <div style="font-size:48px;margin-bottom:16px;opacity:0.4">📭</div>
                <div style="font-family:var(--font-serif);font-size:18px;font-weight:700;color:var(--text-primary);margin-bottom:8px">Database is Empty</div>
                <div style="font-size:13px;color:var(--text-muted);line-height:1.6">@_error</div>
            </div>
        }
        else if (_monsters == null || _monsters.Count == 0)
        {
            <div class="card" style="text-align:center;padding:48px 32px;color:var(--text-muted)">
                <div style="font-size:48px;margin-bottom:16px;opacity:0.4">🔍</div>
                <div style="font-family:var(--font-serif);font-size:16px;font-style:italic">
                    @(_monsters == null ? "Adjust parameters and click Filter Bestiary to begin." : "No monsters found matching these attributes.")
                </div>
            </div>
        }
        else
        {
            var m = _monsters[_index];

            <!-- Nav header -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px">
                <button class="btn btn-ghost" style="padding:10px 22px;font-size:18px"
                        @onclick="Prev" disabled="@(_index == 0)">◀</button>

                <div style="text-align:center">
                    <div style="font-family:var(--font-serif);font-size:14px;color:var(--text-primary);font-weight:700">
                        Entry @(_index + 1) of @_monsters.Count
                    </div>
                    <div style="font-size:11px;color:var(--text-muted);margin-top:2px">
                        matching creatures
                    </div>
                </div>

                <button class="btn btn-ghost" style="padding:10px 22px;font-size:18px"
                        @onclick="Next" disabled="@(_index >= _monsters.Count - 1)">▶</button>
            </div>

            <!-- Full-width monster stat block -->
            <div class="card" style="padding:0;overflow:hidden">
                <img src="@m["image"]" alt="@m["name"]"
                     onerror="this.onerror=null;this.src='https://placehold.co/800x340/2b1f1a/d4af37?text=No+Image+Available';"
                     style="width:100%;height:340px;object-fit:cover;display:block;border-bottom:3px solid var(--red-primary)" />

                <div style="padding:28px">
                    <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
                        <div>
                            <h2 style="font-family:var(--font-serif);font-size:28px;font-weight:700;color:var(--red-primary);margin:0">@m["name"]</h2>
                            <div style="font-size:13px;color:var(--text-muted);font-style:italic;margin-top:4px">@m["alignment"]</div>
                        </div>
                        <div style="text-align:right">
                            <div style="font-size:22px;font-weight:700;color:var(--gold);font-family:var(--font-serif)">CR @m["cr"]</div>
                            <div style="font-size:12px;color:var(--text-muted)">@m["xp"] XP</div>
                        </div>
                    </div>

                    <!-- Divider -->
                    <div style="height:2px;background:linear-gradient(to right,var(--red-primary),transparent);margin-bottom:20px"></div>

                    <!-- Ability score row — D&D stat block style -->
                    <div class="stat-block" style="margin-bottom:20px">
                        @foreach (var (label, key) in new[] { ("STR","str"),("DEX","dex"),("CON","con") })
                        {
                            int score = Convert.ToInt32(m[key]);
                            int mod = (score - 10) / 2;
                            string modStr = mod >= 0 ? $"+{mod}" : $"{mod}";
                            <div class="stat-block-item">
                                <div class="stat-block-label">@label</div>
                                <div class="stat-block-value">@score</div>
                                <div class="stat-block-mod">(@modStr)</div>
                            </div>
                        }
                        <div class="stat-block-divider"></div>
                        <div class="stat-block-item">
                            <div class="stat-block-label" style="color:var(--text-muted)">AC</div>
                            <div class="stat-block-value">@m["ac"]</div>
                        </div>
                        <div class="stat-block-item">
                            <div class="stat-block-label" style="color:var(--text-muted)">HP</div>
                            <div class="stat-block-value">@m["hp"]</div>
                        </div>
                    </div>

                    <button class="btn btn-primary" style="width:100%;padding:14px"
                            @onclick='() => AddToDungeon(m["id"]?.ToString() ?? "")'>
                        ⚔️ Add to Dungeon
                    </button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private int _minStr = 0;
    private int _maxStr = 30;
    private int _minDex = 0;
    private int _maxDex = 30;
    private int _minCon = 0;
    private int _maxCon = 30;

    private string? _lastQuery;
    private string? _error;
    private List<Dictionary<string, object?>>? _monsters;
    private int _index = 0;

    protected override void OnInitialized()
    {
        var stats = Svc.GetStats();
        if (stats.Monsters > 0)
            Search();
        else
            _error = "Please visit the Dashboard to build the database first.";
    }

    private void Search()
    {
        _error = null;
        _index = 0;
        if (_minStr > _maxStr) (_minStr, _maxStr) = (_maxStr, _minStr);
        if (_minDex > _maxDex) (_minDex, _maxDex) = (_maxDex, _minDex);
        if (_minCon > _maxCon) (_minCon, _maxCon) = (_maxCon, _minCon);

        _lastQuery = $@"MATCH (m:Monster)
WHERE m.str >= {_minStr} AND m.str <= {_maxStr}
  AND m.dex >= {_minDex} AND m.dex <= {_maxDex}
  AND m.con >= {_minCon} AND m.con <= {_maxCon}
RETURN m.id AS id, m.name AS name, m.image AS image,
       m.cr AS cr, m.xp AS xp, m.ac AS ac, m.hp AS hp,
       m.str AS str, m.dex AS dex, m.con AS con,
       m.alignment AS alignment
ORDER BY m.xp DESC";

        var res = Svc.Execute(_lastQuery);
        if (!res.IsSuccess)
        {
            _error = res.Error;
            _monsters = null;
        }
        else
        {
            _monsters = res.Rows;
        }
    }

    private void Prev()
    {
        if (_index > 0) _index--;
    }

    private void Next()
    {
        if (_monsters != null && _index < _monsters.Count - 1) _index++;
    }

    private void AddToDungeon(string monsterId)
    {
        if (string.IsNullOrEmpty(monsterId)) return;
        Svc.AddToDungeon(monsterId, "dungeon-1");
    }
}
