@page "/querylab"
@rendermode InteractiveServer
@inject SqlToCypherGraphService Svc

<PageTitle>Query Lab · SQL→Cypher</PageTitle>

<div class="page-header">
    <h1>⌨️ Query Lab</h1>
    <p>Free-form Cypher editor. Write any query against the e-commerce, employees, or movies graph.</p>
</div>

<div class="card">
    <div class="form-row" style="align-items:flex-start">
        <div class="form-group" style="flex:1">
            <label>Cypher Query</label>
            <textarea id="cypher-lab-input" class="cypher-editor" style="height:180px"
                      @bind="_cypher" spellcheck="false"></textarea>
        </div>
    </div>

    <div style="display:flex;gap:10px;align-items:center;margin-bottom:12px">
        <button id="btn-run-lab" class="btn btn-primary" @onclick="RunQuery">▶ Run Query</button>
        <button class="btn btn-ghost" @onclick="ClearQuery">✕ Clear</button>
        @if (_response is not null)
        {
            <span class="result-meta">@_response.Rows.Count row@(_response.Rows.Count == 1?"":"s") · @_response.ElapsedMs ms</span>
        }
    </div>

    @if (_loading)
    {
        <div class="loading"><div class="spinner"></div>Executing…</div>
    }
    else if (_response is not null)
    {
        if (!_response.IsSuccess)
        {
            <div class="alert alert-error">@_response.Error</div>
        }
        else if (_response.Rows.Count == 0)
        {
            <div class="alert alert-info">No rows returned.</div>
        }
        else
        {
            <div class="results-table-wrap">
                <table class="data-table">
                    <thead><tr>@foreach (var col in _response.Columns) { <th>@col</th> }</tr></thead>
                    <tbody>
                        @foreach (var row in _response.Rows.Take(200))
                        {
                            <tr>
                                @foreach (var col in _response.Columns)
                                {
                                    <td>@(row.TryGetValue(col, out var v) ? v?.ToString() ?? "null" : "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

<div class="card">
    <div class="card-title">📌 Quick-start queries</div>
    <div class="qstart-grid">
        @foreach (var q in _quickStart)
        {
            <div class="qstart-item">
                <div class="qstart-top">
                    <span class="qstart-domain qstart-@q.Domain">@q.Domain</span>
                    <span class="qstart-title">@q.Title</span>
                </div>
                <pre class="qstart-preview">@q.Cypher</pre>
                <button class="btn btn-ghost" style="margin-top:6px;font-size:11px;padding:4px 10px"
                        @onclick="() => LoadQuery(q.Cypher)">Load →</button>
            </div>
        }
    </div>
</div>

@code {
    private string _cypher = "MATCH (c:Customer) RETURN c.name, c.country, c.joined_year ORDER BY c.name LIMIT 20";
    private QueryResult? _response;
    private bool _loading;

    private record QuickQuery(string Title, string Domain, string Cypher);

    private readonly QuickQuery[] _quickStart =
    [
        new("All customers", "E-commerce",
            "MATCH (c:Customer) RETURN c.name, c.country, c.joined_year ORDER BY c.name LIMIT 20"),
        new("Top products by price", "E-commerce",
            "MATCH (p:Product) RETURN p.name, p.price ORDER BY p.price DESC LIMIT 10"),
        new("Orders per customer", "E-commerce",
            "MATCH (c:Customer)-[:PLACED]->(o:`Order`)\nWITH c.name AS customer, COUNT(o) AS orders, SUM(o.amount) AS total\nRETURN customer, orders, total\nORDER BY total DESC"),
        new("Products ordered by Alice", "E-commerce",
            "MATCH (c:Customer {name:'Alice Smith'})-[:PLACED]->(o:`Order`)-[:CONTAINS]->(p:Product)\nRETURN DISTINCT p.name, p.price"),
        new("Customers who never ordered", "E-commerce",
            "MATCH (c:Customer) WHERE NOT (c)-[:PLACED]->()\nRETURN c.name, c.country"),
        new("Employees by department", "Employees",
            "MATCH (e:Employee)-[:WORKS_IN]->(d:Department)\nRETURN d.name AS department, COUNT(e) AS headcount, AVG(e.salary) AS avg_salary\nORDER BY headcount DESC"),
        new("Reporting chain from Alice", "Employees",
            "MATCH (mgr:Employee {name:'Alice Smith'})-[:MANAGES*1..3]->(r:Employee)\nRETURN r.name, r.title"),
        new("Project assignments", "Employees",
            "MATCH (e:Employee)-[a:ASSIGNED_TO]->(p:Project)\nRETURN e.name, p.name AS project, a.role\nORDER BY p.name, e.name"),
        new("Top-rated movies", "Movies",
            "MATCH (m:Movie) RETURN m.title, m.year, m.rating ORDER BY m.rating DESC LIMIT 10"),
        new("Actor filmographies", "Movies",
            "MATCH (p:Person)-[a:ACTED_IN]->(m:Movie)\nRETURN p.name, COLLECT(m.title + ' (' + toString(m.year) + ')') AS films\nORDER BY p.name"),
        new("Drama movies with rating > 8.5", "Movies",
            "MATCH (m:Movie)-[:IN_GENRE]->(g:Genre {name:'Drama'})\nWHERE m.rating > 8.5\nRETURN m.title, m.year, m.rating\nORDER BY m.rating DESC"),
        new("Director / actor crossover", "Movies",
            "MATCH (p:Person)-[:DIRECTED]->(m:Movie)<-[:ACTED_IN]-(a:Person)\nRETURN p.name AS director, m.title, COLLECT(a.name) AS cast\nORDER BY p.name"),
    ];

    private async Task RunQuery()
    {
        if (string.IsNullOrWhiteSpace(_cypher)) return;
        _loading = true;
        StateHasChanged();
        await Task.Yield();
        _response = Svc.Execute(_cypher);
        _loading = false;
    }

    private void LoadQuery(string cypher) { _cypher = cypher; _response = null; }
    private void ClearQuery() { _cypher = ""; _response = null; }
}
