    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>BogDb.Samples.PackageEcosystem.Blazor</RootNamespace>
    <AssemblyName>BogDb.Samples.PackageEcosystem.Blazor</AssemblyName>
  </PropertyGroup>

</Project>
