{
  "name": "claim-renew.success",
  "verb": "renew",
  "depends_on": ["claim-grant.success"],
  "request": {
    "method": "POST",
    "path": "claims/${claim_id}/renew",
    "headers": {
      "Content-Type": "application/json",
      "Authorization": "Bearer ${worker_http_token}"
    },
    "body": {
      "protocol_version": "acop/1.0",
      "worker_agent_uid": "worker-http",
      "requested_ttl_seconds": 1800,
      "progress_summary": "extracted HTTP seam, running targeted tests"
    }
  },
  "expected_response": {
    "status": 200,
    "body_match": {
      "kind": "subset",
      "value": {
        "protocol_version": "acop/1.0",
        "claim": {
          "claim_id": "${claim_id}",
          "worker_agent_uid": "worker-http",
          "claim_status": "active"
        }
      }
    }
  }
}
