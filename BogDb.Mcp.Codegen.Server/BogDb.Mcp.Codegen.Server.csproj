<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>bogdb-codegen-mcp</ToolCommandName>
    <PackageId>BogDB.Mcp.Codegen.Server</PackageId>
    <Title>BogDB Codegen MCP Server</Title>
    <Description>Model Context Protocol code-generation server for natural-language Cypher workflows with BogDB.</Description>
    <SkipDefaultPackageReadme>true</SkipDefaultPackageReadme>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\BogDb.Core\BogDb.Core.csproj" />
    <ProjectReference Include="..\BogDb.Mcp.Server\BogDb.Mcp.Server.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
