@inherits LayoutComponentBase

<div class="app-shell">
    <nav class="sidebar">
        <div class="sidebar-brand">
            <span class="brand-icon">📡</span>
            <div>
                <span class="brand-name">TacMsg</span>
                <span class="brand-sub">Compliance Graph</span>
            </div>
        </div>
        <div class="tier-badge">
            <span class="tier-label">STANDARDS · SYSTEM · ASSURANCE</span>
            <span class="tier-sub">Impact analysis engine</span>
        </div>
        <ul class="nav-list">
            <li><NavLink href="" Match="NavLinkMatch.All" class="nav-link"><span class="nav-icon">🏠</span>Dashboard</NavLink></li>
            <li><NavLink href="impact" class="nav-link"><span class="nav-icon">💥</span>Impact Analysis</NavLink></li>
            <li><NavLink href="certification" class="nav-link"><span class="nav-icon">📋</span>Certification Chain</NavLink></li>
            <li><NavLink href="drift" class="nav-link"><span class="nav-icon">📊</span>Baseline Drift</NavLink></li>
            <li><NavLink href="consensus" class="nav-link"><span class="nav-icon">🔗</span>Consensus Report</NavLink></li>
            <li><NavLink href="platforms" class="nav-link"><span class="nav-icon">🚢</span>Platform Exposure</NavLink></li>
            <li><NavLink href="gaps" class="nav-link"><span class="nav-icon">⚠️</span>Compliance Gaps</NavLink></li>
            <li><NavLink href="query" class="nav-link"><span class="nav-icon">🔎</span>Query Editor</NavLink></li>
        </ul>
        <div class="sidebar-footer">
            <span class="badge badge-blue">BogDB</span>
            <span class="badge badge-teal">WS39</span>
            <span class="badge badge-amber">L16</span>
        </div>
    </nav>
    <main class="main-content">
        @Body
    </main>
</div>

<style>
.app-shell { display: flex; height: 100vh; overflow: hidden; }
.sidebar { width: 230px; min-width: 230px; background: var(--glass-bg); border-right: 1px solid var(--glass-border); display: flex; flex-direction: column; padding: 1.5rem 1rem; gap: 1rem; overflow-y: auto; }
.sidebar-brand { display: flex; align-items: center; gap: 0.75rem; padding-bottom: 1rem; border-bottom: 1px solid var(--glass-border); }
.brand-icon { font-size: 1.8rem; }
.brand-name { display: block; font-weight: 700; font-size: 1rem; color: var(--text-primary); }
.brand-sub { display: block; font-size: 0.68rem; color: var(--text-muted); }
.tier-badge { background: rgba(74,127,199,0.08); border: 1px solid rgba(74,127,199,0.2); border-radius: 6px; padding: 0.5rem 0.6rem; }
.tier-label { display: block; font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; color: var(--accent); }
.tier-sub { display: block; font-size: 0.68rem; color: var(--text-muted); margin-top: 0.1rem; }
.nav-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.25rem; flex: 1; }
.nav-link { display: flex; align-items: center; gap: 0.6rem; padding: 0.6rem 0.75rem; border-radius: 8px; color: var(--text-secondary); text-decoration: none; font-size: 0.875rem; font-weight: 500; transition: all 0.2s; }
.nav-link:hover, .nav-link.active { background: var(--accent-glow); color: var(--accent); }
.nav-icon { font-size: 1rem; width: 1.2rem; text-align: center; }
.sidebar-footer { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.main-content { flex: 1; overflow-y: auto; padding: 2rem; }
</style>
