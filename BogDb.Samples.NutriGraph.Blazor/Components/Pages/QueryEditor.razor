@page "/query"
@rendermode InteractiveServer
@inject BogDb.Samples.NutriGraph.Blazor.Services.NutriGraphService Svc

<PageTitle>Cypher Editor · NutriGraph</PageTitle>

<div class="page-header">
    <h1>⌨️ Cypher Editor</h1>
    <p>Run any Cypher query against the live nutrition graph — explore recipes, nutrients, ingredients, and allergens interactively</p>
</div>

<div class="card">
    <div class="form-row" style="align-items:flex-start">
        <div class="form-group" style="flex:1">
            <label>Cypher Query</label>
            <textarea id="cypher-input" class="cypher-editor" @bind="_cypher" placeholder="MATCH (r:Recipe)-[:CONTAINS]->(i:Ingredient) RETURN r.title, collect(i.name)"></textarea>
        </div>
    </div>
    <div style="display:flex;gap:10px;align-items:center">
        <button id="btn-run" class="btn btn-primary" @onclick="RunQuery">▶ Run Query</button>
        <button class="btn btn-ghost" @onclick="ClearQuery">Clear</button>
        @if (_response is not null)
        {
            <span style="font-size:12px;color:var(--text-muted)">
                @_response.Rows.Count row@(_response.Rows.Count == 1 ? "" : "s") · @_response.ElapsedMs ms
            </span>
        }
    </div>

    @if (_loading)
    {
        <div class="loading" style="margin-top:12px"><div class="spinner"></div>Executing…</div>
    }
    else if (_response is not null)
    {
        if (!_response.IsSuccess)
        {
            <div class="alert alert-error" style="margin-top:12px">@_response.Error</div>
        }
        else if (_response.Rows.Count == 0)
        {
            <div class="alert alert-info" style="margin-top:12px">Query returned no rows. Populate the graph first via Recipe Search.</div>
        }
        else
        {
            <div class="results-table-wrap" style="margin-top:14px">
                <table class="data-table">
                    <thead>
                        <tr>
                            @foreach (var col in _response.Columns)
                            {
                                <th>@col</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in _response.Rows.Take(200))
                        {
                            <tr>
                                @foreach (var col in _response.Columns)
                                {
                                    <td>@(row.TryGetValue(col, out var v) ? v?.ToString() ?? "null" : "")</td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (_response.Rows.Count > 200)
            {
                <p class="text-muted" style="margin-top:8px;font-size:12px">
                    Showing first 200 of @_response.Rows.Count rows.
                </p>
            }
        }
    }
</div>

<div class="card">
    <div class="card-title">📌 Showcase Queries</div>
    <div style="display:flex;flex-direction:column;gap:8px">
        @foreach (var (label, cypher) in NutriGraphService.ShowcaseQueries)
        {
            <div style="display:flex;align-items:flex-start;gap:12px;padding:8px 0;border-bottom:1px solid var(--border)">
                <button class="btn btn-ghost" style="padding:5px 12px;font-size:12px;white-space:nowrap"
                        @onclick="() => LoadQuery(cypher)">Load</button>
                <div>
                    <div style="font-weight:600;color:var(--teal-300);font-size:13px">@label</div>
                    <pre style="font-family:var(--font-mono);font-size:11px;color:var(--text-muted);white-space:pre-wrap;margin:4px 0 0">@cypher</pre>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private string _cypher = "MATCH (r:Recipe)-[:CONTAINS]->(i:Ingredient)\nRETURN r.title, collect(i.name) AS ingredients\nORDER BY r.title\nLIMIT 10;";
    private QueryResponse? _response;
    private bool _loading;

    private async Task RunQuery()
    {
        if (string.IsNullOrWhiteSpace(_cypher)) return;
        _loading = true;
        StateHasChanged();
        await Task.Yield();
        _response = Svc.Execute(_cypher);
        _loading = false;
    }

    private void LoadQuery(string cypher) => _cypher = cypher;
    private void ClearQuery() { _cypher = ""; _response = null; }
}
